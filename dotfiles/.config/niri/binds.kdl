// ============================================
// 快捷键绑定 — Shorin Niri 精简版
// 保留完整快捷键体系，仅移除自研扩展引用
// 适配 ThinkPad T430 / Fedora 44 / Plasma 6
// ============================================

binds {
    // ============================================
    // 帮助与教程
    // ============================================
    // 显示快捷键速查表 (从所有 kdl 提取 hotkey-overlay-title)
    Mod+Shift+Slash hotkey-overlay-title="快捷键教程 Keybind tutorial" { spawn "~/.config/niri/scripts/niri-binds"; }

    // ============================================
    // Alt+Tab 快速窗口切换 (fzf 菜单)
    // ============================================
    Alt+Tab hotkey-overlay-title="快速跳转窗口 Quick window switch menu" { spawn "~/.config/niri/scripts/niri-quick-switch-fuzzel.py"; }

    // ============================================
    // 壁纸相关
    // ============================================
    Mod+Alt+W       hotkey-overlay-title="切换壁纸 Change wallpaper" { spawn "waypaper"; }
    Mod+Alt+M       hotkey-overlay-title="切换颜色策略 Change color strategy" { spawn "~/.config/scripts/matugen-select-type.sh"; }
    Mod+Alt+T       hotkey-overlay-title="切换颜色策略 Change color strategy" { spawn "~/.config/scripts/matugen-select-type.sh"; }
    Mod+F10         hotkey-overlay-title="随机切换壁纸 Random wallpaper" { spawn "waypaper" "--random"; }
    // 随机下载动漫壁纸功能已移除 (非刚需)

    // ============================================
    // Waybar 开关与切换
    // ============================================
    Mod+F2          hotkey-overlay-title=null  { spawn-sh "pkill cava || true && pkill waybar || true && waybar -c $HOME/.config/waybar/config.jsonc -s $HOME/.config/waybar/style.css "; }
    Mod+F3          hotkey-overlay-title=null  { spawn-sh "pkill cava || true && pkill waybar || true && waybar -c $HOME/.config/waybar-niri-Win11Like/config.jsonc -s $HOME/.config/waybar-niri-Win11Like/style.css "; }
    Mod+Shift+F4    hotkey-overlay-title="隐藏任务栏 Hide bar" { spawn-sh "killall -SIGUSR1 waybar"; }
    Mod+F4          hotkey-overlay-title="开关任务栏 Toggle bar" { spawn-sh "pkill waybar && pkill cava || waybar "; }

    // ============================================
    // Btrfs 快照 (quicksave / quickload)
    // ============================================
    Mod+F5          hotkey-overlay-title="快速存档 Quick save" { spawn "quicksave"; }
    Mod+F8          hotkey-overlay-title="快速读档 Quick load" { spawn "quickload"; }

    // ============================================
    // 截图
    // ============================================
    Mod+F12         hotkey-overlay-title="截取所有显示器 Screenshot All Monitor"  { spawn-sh "grim - | wl-copy"; }
    Mod+Alt+A       hotkey-overlay-title="选取区域截图 Select screenshot"  { spawn-sh "niri msg action screenshot --show-pointer false"; }
    Mod+Alt+Ctrl+A  hotkey-overlay-title="截取聚焦窗口 Focus-window screenshot" { spawn-sh "niri msg action screenshot-window"; }
    Mod+Alt+Ctrl+Shift+A hotkey-overlay-title="截取显示器 Monitor screenshot" { spawn-sh "niri msg action screenshot-screen --show-pointer false"; }
    Print           hotkey-overlay-title=null { spawn-sh "niri msg action screenshot --show-pointer false"; }
    Ctrl+Print      hotkey-overlay-title=null { spawn-sh "niri msg action screenshot-window"; }
    Shift+Print     hotkey-overlay-title=null { spawn-sh "niri msg action screenshot-screen --show-pointer false"; }
    Mod+Shift+S     hotkey-overlay-title="截图后编辑 Edit screenshot" { spawn-sh "wl-paste | satty -f -"; }

    // ============================================
    // 终端
    // ============================================
    Mod+Slash       hotkey-overlay-title="临时终端 Quick Terminal" { spawn "kitty" "--single-instance" "--class" "quickterminal"; }
    Mod+T           hotkey-overlay-title="共享终端 Terminal" { spawn "kitty" "--single-instance"; }
    Mod+Return      hotkey-overlay-title="独立终端 Terminal" { spawn "kitty"; }

    // ============================================
    // 应用程序启动
    // ============================================
    Mod+B           hotkey-overlay-title="浏览器 Browser" { spawn "firefox"; }
    Mod+E           hotkey-overlay-title="文档管理器 Filemanager" { spawn-sh "thunar || env GSK_RENDERER=gl nautilus --new-window"; }
    Mod+Alt+E       hotkey-overlay-title=null { spawn "env" "GSK_RENDERER=gl" "nautilus" "--new-window"; }
    Mod+Z           hotkey-overlay-title="程序菜单 Applauncher" { spawn "fuzzel"; }

    // ============================================
    // 锁屏 / 电源
    // ============================================
    Mod+Alt+L       hotkey-overlay-title="锁屏 Lock screen" { spawn-sh "hyprlock -c ~/.config/niri/hyprlock.conf"; }
    Mod+Shift+P     hotkey-overlay-title="电源菜单 Power menu" { spawn "~/.config/niri/scripts/powermenu"; }

    // ============================================
    // 剪贴板
    // ============================================
    Mod+Alt+V       hotkey-overlay-title="剪贴板 Clipboard" { spawn-sh "kitty --single-instance --class cliphist-tui -e cliphist-tui"; }

    // ============================================
    // 输入法
    // ============================================
    Mod+F1          hotkey-overlay-title="开关输入法 Toggle fcitx" { spawn-sh "pkill fcitx5 || fcitx5 "; }

    // ============================================
    // 音量 / 亮度 (硬件键)
    // ============================================
    XF86AudioRaiseVolume   allow-when-locked=true { spawn-sh "swayosd-client --output-volume +5"; }
    XF86AudioLowerVolume   allow-when-locked=true { spawn-sh "swayosd-client --output-volume -5"; }
    XF86AudioMute          allow-when-locked=true { spawn-sh "swayosd-client --output-volume mute-toggle"; }
    XF86AudioMicMute       allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }
    XF86MonBrightnessUp    allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+5%"; }
    XF86MonBrightnessDown  allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "5%-"; }

    // ============================================
    // Overview (工作区总览)
    // ============================================
    Mod+O hotkey-overlay-title="切换总览 Toggle overview" repeat=false { toggle-overview; }
    Mod+G hotkey-overlay-title="切换总览 Toggle overview" repeat=false { toggle-overview; }

    // ============================================
    // 窗口关闭 / 杀死
    // ============================================
    Mod+Q            hotkey-overlay-title="关闭聚焦窗口 Close window" repeat=false { close-window; }
    Alt+F4           hotkey-overlay-title="强制杀死窗口 Force kill" repeat=false { spawn "~/.config/niri/scripts/niri-force-kill-window"; }
    Alt+Shift+F4     hotkey-overlay-title="强制杀死进程树 Force kill tree" repeat=false { spawn "~/.config/niri/scripts/niri-force-kill-window" "-f"; }
    Mod+MouseMiddle  { close-window; }

    // ============================================
    // *** 核心: 窗口聚焦切换 ***
    // 三套同义键位: 方向键 / HJKL(vim) / WASD
    // ============================================

    // ← → 切换列聚焦 (方向键)
    Mod+Left    { focus-column-left; }
    Mod+Right   { focus-column-right; }
    // ↑ ↓ 切换窗口聚焦 (方向键)
    Mod+Down    { focus-window-down; }
    Mod+Up      { focus-window-up; }

    // HJKL (vim 风格)
    Mod+H { focus-column-left; }
    Mod+L { focus-column-right; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }

    // WASD (游戏风格)
    Mod+A hotkey-overlay-title="向左移动窗口 Move window left" { consume-or-expel-window-left; }
    Mod+D hotkey-overlay-title="向右移动窗口 Move window right" { consume-or-expel-window-right; }
    Mod+W { focus-window-up; }
    Mod+S { focus-window-down; }

    // ============================================
    // *** 核心: 窗口移动 (同列内上下) ***
    // ============================================
    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Right { move-column-right; }
    Mod+Ctrl+Down  { move-window-down; }
    Mod+Ctrl+Up    { move-window-up; }

    Mod+Ctrl+H { move-column-left; }
    Mod+Ctrl+L { move-column-right; }
    Mod+Ctrl+J { move-window-down; }
    Mod+Ctrl+K { move-window-up; }

    Mod+Ctrl+A { move-column-left; }
    Mod+Ctrl+D { move-column-right; }
    Mod+Ctrl+S { move-window-down; }
    Mod+Ctrl+W { move-window-up; }

    // ============================================
    // 列的首尾跳转
    // ============================================
    Mod+Home { focus-column-first; }
    Mod+End  { focus-column-last; }
    Mod+Ctrl+Home { move-column-to-first; }
    Mod+Ctrl+End  { move-column-to-last; }

    // ============================================
    // *** 多显示器 ***
    // ============================================
    Mod+Shift+Left  { focus-monitor-left; }
    Mod+Shift+Right { focus-monitor-right; }
    Mod+Shift+Down  { focus-monitor-down; }
    Mod+Shift+Up    { focus-monitor-up; }

    Mod+Shift+H { focus-monitor-left; }
    Mod+Shift+L { focus-monitor-right; }
    Mod+Shift+J { focus-monitor-down; }
    Mod+Shift+K { focus-monitor-up; }

    // 跨显示器移动列
    Mod+Shift+Ctrl+Left  { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+Right { move-column-to-monitor-right; }
    Mod+Shift+Ctrl+Down  { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+Up    { move-column-to-monitor-up; }

    Mod+Shift+Ctrl+H { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+L { move-column-to-monitor-right; }
    Mod+Shift+Ctrl+J { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+K { move-column-to-monitor-up; }

    Mod+Shift+Ctrl+A { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+D { move-column-to-monitor-right; }
    Mod+Shift+Ctrl+W { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+S { move-column-to-monitor-down; }

    // 跨显示器移动整个工作区
    Mod+Shift+Alt+W  { move-workspace-to-monitor-up; }
    Mod+Shift+Alt+S  { move-workspace-to-monitor-down; }
    Mod+Shift+Alt+D  { move-workspace-to-monitor-right; }
    Mod+Shift+Alt+A  { move-workspace-to-monitor-left; }
    Mod+Shift+Alt+K  { move-workspace-to-monitor-up; }
    Mod+Shift+Alt+J  { move-workspace-to-monitor-down; }
    Mod+Shift+Alt+L  { move-workspace-to-monitor-right; }
    Mod+Shift+Alt+H  { move-workspace-to-monitor-left; }
    Mod+Shift+Alt+Up    { move-workspace-to-monitor-up; }
    Mod+Shift+Alt+Down  { move-workspace-to-monitor-down; }
    Mod+Shift+Alt+Right { move-workspace-to-monitor-right; }
    Mod+Shift+Alt+Left  { move-workspace-to-monitor-left; }

    // ============================================
    // *** 工作区切换 ***
    // ============================================
    Mod+Page_Down hotkey-overlay-title=null { focus-workspace-down; }
    Mod+Page_Up   hotkey-overlay-title=null { focus-workspace-up; }
    Mod+U { focus-workspace-down; }
    Mod+I { focus-workspace-up; }

    Mod+Ctrl+Page_Down { move-column-to-workspace-down; }
    Mod+Ctrl+Page_Up   { move-column-to-workspace-up; }
    Mod+Ctrl+U { move-column-to-workspace-down; }
    Mod+Ctrl+I { move-column-to-workspace-up; }

    // 数字键切换工作区
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }
    Mod+Ctrl+4 { move-column-to-workspace 4; }
    Mod+Ctrl+5 { move-column-to-workspace 5; }
    Mod+Ctrl+6 { move-column-to-workspace 6; }
    Mod+Ctrl+7 { move-column-to-workspace 7; }
    Mod+Ctrl+8 { move-column-to-workspace 8; }
    Mod+Ctrl+9 { move-column-to-workspace 9; }

    // 滚轮切换工作区
    Mod+Shift+WheelScrollDown  hotkey-overlay-title="切换工作区 Change workspaces" cooldown-ms=150 { focus-workspace-down; }
    Mod+Shift+WheelScrollUp    cooldown-ms=150 { focus-workspace-up; }
    Mod+Ctrl+Shift+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+Shift+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }

    // 滚轮切换聚焦
    Mod+WheelScrollDown hotkey-overlay-title="滚轮切换聚焦"  { focus-column-right; }
    Mod+WheelScrollUp   { focus-column-left; }
    Mod+Ctrl+WheelScrollDown { move-column-right; }
    Mod+Ctrl+WheelScrollUp   { move-column-left; }

    // ============================================
    // 窗口合并 / 拆分 / 标签页
    // ============================================
    Mod+BracketLeft  { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }
    Mod+Comma  { consume-window-into-column; }
    Mod+Period { expel-window-from-column; }
    Mod+Shift+A  { consume-window-into-column; }
    Mod+Shift+D  { expel-window-from-column; }
    Mod+Shift+X  { toggle-column-tabbed-display; }
    Mod+X        { toggle-column-tabbed-display; }

    // ============================================
    // 鼠标侧键
    // ============================================
    Mod+MouseForward { focus-window-up; }
    Mod+MouseBack    { focus-window-down; }

    // ============================================
    // 窗口尺寸调整
    // ============================================
    Mod+R  hotkey-overlay-title="按预设切换宽度 Switch width" { switch-preset-column-width; }
    Mod+Shift+R  { switch-preset-window-height; }
    Mod+Ctrl+R   { reset-window-height; }

    Mod+F  hotkey-overlay-title="最大化 Maximize" { maximize-column; }
    Mod+Alt+F hotkey-overlay-title="全屏 Fullscreen" { fullscreen-window; }
    Mod+Ctrl+F { expand-column-to-available-width; }

    Mod+C { center-column; }
    Mod+Ctrl+C { center-visible-columns; }

    // 精细调整窗口宽度 (±5%)
    Mod+Minus { set-column-width "-5%"; }
    Mod+Equal { set-column-width "+5%"; }

    // 精细调整窗口高度 (±5%)
    Mod+Shift+Minus { set-window-height "-5%"; }
    Mod+Shift+Equal { set-window-height "+5%"; }

    // ============================================
    // 浮动窗口
    // ============================================
    Mod+V   hotkey-overlay-title="切换浮动 Toggle floating"    { toggle-window-floating; }
    Mod+Shift+V hotkey-overlay-title=null { switch-focus-between-floating-and-tiling; }
    Mod+N        hotkey-overlay-title="切换浮动聚焦 Toggle float focus" { switch-focus-between-floating-and-tiling; }
    Mod+Alt+N    hotkey-overlay-title=null { switch-focus-between-floating-and-tiling; }
    Alt+grave    hotkey-overlay-title=null { switch-focus-between-floating-and-tiling; }

    // ============================================
    // 键盘快捷键抑制 (用于远程桌面等场景)
    // ============================================
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }

    // ============================================
    // 退出 niri
    // ============================================
    Mod+Shift+E hotkey-overlay-title="退出 niri Quit niri" { quit; }

    // ============================================
    // 熄屏 (按任意键恢复)
    // ============================================
    // 电源菜单已包含熄屏选项
}
