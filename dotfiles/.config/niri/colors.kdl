// ============================================
// 颜色配置 — 由 matugen 动态生成
// 聚焦环渐变配色，所有 matugen 模板共享
// ============================================
layout {
    focus-ring {
        active-gradient from="#88d6bbcc" to="#a8cbe2cc" angle=135
        urgent-color "#ffb4ab"
    }
}
recent-windows {
    highlight {
        active-color "#343b38"
        urgent-color "#ffb4ab"
    }
}
