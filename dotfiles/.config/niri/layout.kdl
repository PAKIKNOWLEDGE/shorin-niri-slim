// ============================================
// 布局配置 — 精简版
// 保留完整窗口布局逻辑，仅微调阴影降低开销
// ============================================
layout {
    // 窗口间距 (逻辑像素)
    gaps 10

    // 聚焦列居中策略: 从不自动居中 (保持位置稳定)
    center-focused-column "never"

    // 预设窗口宽度 (Mod+R 循环切换)
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    // 新窗口默认宽度
    default-column-width { proportion 0.5; }

    // ---- 聚焦环 ----
    focus-ring {
        width 2
        // 颜色由 colors.kdl 通过 matugen 动态生成
    }

    // ---- 窗口边框 (关闭) ----
    border {
        off
        width 4
        active-color "#ffc87f"
        inactive-color "#505050"
        urgent-color "#9b0000"
    }

    // ---- 窗口阴影 (降低参数减轻渲染压力) ----
    shadow {
        on
        // T430: 降低阴影质量参数
        softness 12          // 原 20 → 12，减少模糊纹理开销
        spread 1             // 原 2  → 1
        offset x=-2 y=-2     // 原 -4  → -2，缩减阴影范围
        color "rgba(0, 0, 0, 0.5)"  // 降低不透明度
    }

    // ---- 屏幕边缘间距 ----
    struts {
        // 全部留空，由 waybar 层壳自动占据空间
    }
}
