// ============================================
// 显示器配置模板 — 多显示器示例
// 复制到 output.kdl 并根据实际设备修改
// ============================================

// 内置笔记本屏幕
output "eDP-1" {
    mode "1366x768@60"
    scale 1
    position x=0 y=0
}

// 外接显示器 (如通过 T430 的 MiniDP 接口)
// output "DP-1" {
//     mode "1920x1080@60"
//     scale 1
//     position x=1366 y=0
//     focus-at-startup
// }
